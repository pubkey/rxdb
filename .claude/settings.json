{
    "buildCommand": "npm run build",
    "testCommand": "npm run test:fast:memory",
    "lintCommand": "npm run lint",
    "permissions": {
        "allow": [
            "Bash(npm run *)",
            "Bash(npm install:*)",
            "Bash(cat:*)",
            "Bash(ls:*)",
            "Bash(grep:*)",
            "Bash(node:*)",
            "Bash(npx:*)",
            "Bash(mkdir:*)",
            "Bash(cp:*)",
            "Bash(mv:*)",
            "Bash(head:*)",
            "Bash(tail:*)",
            "Bash(wc:*)",
            "Bash(find:*)",
            "Bash(echo:*)",
            "Bash(pwd:*)"
        ],
        "deny": [
            "Write(plugins/**)",
            "Edit(plugins/**)",
            "Delete(plugins/**)"
        ]
    },
    "hooks": {
        "PreToolUse": [
            {
                "matcher": "Bash",
                "hooks": [
                    {
                        "type": "command",
                        "command": "npx block-no-verify@1.1.2"
                    }
                ]
            }
        ]
    }
}
