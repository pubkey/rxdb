{
    "buildCommand": "npm run build",
    "testCommand": "npm run test:fast:memory",
    "lintCommand": "npm run lint",
    "permissions": {
        "allow": [
            "Bash(npm run lint*)",
            "Bash(npm run test*)",
            "Bash(npm install:*)",
            "Bash(npm run build:*)",
            "Bash(npm run check-types:*)",
            "Bash(npm run generate:*)",
            "Bash(npx:*)",
            "Bash(node:*)"
        ],
        "deny": [
            "Write(plugins/**)",
            "Edit(plugins/**)",
            "Delete(plugins/**)"
        ]
    }
}